APP_NAME="Chao Du Booking"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Jakarta

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=chaodu
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
PACKAGE_IMAGE_DISK=public
PACKAGE_IMAGE_MAX_KB=2048
BOOKING_PRIVATE_DISK=local
BOOKING_MAX_ATTENDEE_COUNT=20
BOOKING_UPLOAD_MAX_MB=5
BOOKING_SUBMIT_RATE_LIMIT_MAX_ATTEMPTS=6
BOOKING_SUBMIT_RATE_LIMIT_DECAY_SECONDS=60

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"
BREVO_API_KEY=
BREVO_BASE_URL=https://api.brevo.com/v3
DISCORD_GENERAL_BOOKING_WEBHOOK_URL=
DISCORD_AGENT_BOOKING_WEBHOOK_URL=
DISCORD_WEBHOOK_USERNAME="${APP_NAME}"
DISCORD_WEBHOOK_TIMEOUT_SECONDS=5
DISCORD_WEBHOOK_RETRY_TIMES=1

R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_DEFAULT_REGION=auto
R2_BUCKET=
R2_ENDPOINT=
R2_URL=
R2_USE_PATH_STYLE_ENDPOINT=true

GOOGLE_SERVICE_ACCOUNT_JSON_PATH=
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_DRIVE_SHARE_ANYONE_WITH_LINK=true
NOTION_API_TOKEN=
NOTION_PARENT_ID=
NOTION_PARENT_TYPE=page_id
NOTION_VERSION=2022-06-28
APPROVAL_FILE_DISK=local
PRAYER_PAPER_LATIN_FONT_PATHS=
PRAYER_PAPER_CJK_FONT_PATHS=
CAPTCHA_ENABLED=false
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=
CAPTCHA_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

DEFAULT_ADMIN_NAME="Admin Chao Du"
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=password
DEFAULT_CHECKER_NAME="Checker Chao Du"
DEFAULT_CHECKER_EMAIL=checker@example.com
DEFAULT_CHECKER_PASSWORD=password
DEFAULT_PRINTER_NAME="Petugas Print Chao Du"
DEFAULT_PRINTER_EMAIL=printer@example.com
DEFAULT_PRINTER_PASSWORD=password

VITE_APP_NAME="${APP_NAME}"
